{
  "annotations": { "list": [] },
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [{ "expr": "sum by (app_id) (pulsews_connections)", "legendFormat": "{{app_id}}", "refId": "A" }],
      "title": "Connections by app",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [{ "expr": "sum by (direction) (rate(pulsews_messages_total[1m]))", "legendFormat": "{{direction}}", "refId": "A" }],
      "title": "Message throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(pulsews_delivery_latency_seconds_bucket{scope=\"same_node\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(pulsews_delivery_latency_seconds_bucket{scope=\"same_node\"}[5m])))", "legendFormat": "p99", "refId": "B" }
      ],
      "title": "Same-node delivery latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(pulsews_delivery_latency_seconds_bucket{scope=\"cross_node\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(pulsews_delivery_latency_seconds_bucket{scope=\"cross_node\"}[5m])))", "legendFormat": "p99", "refId": "B" }
      ],
      "title": "Cross-node delivery latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 5,
      "targets": [{ "expr": "sum by (reason) (increase(pulsews_dropped_messages_total[5m]))", "legendFormat": "{{reason}}", "refId": "A" }],
      "title": "Dropped messages by reason",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 6,
      "targets": [{ "expr": "sum by (reason) (increase(pulsews_client_event_rejections_total[5m]))", "legendFormat": "{{reason}}", "refId": "A" }],
      "title": "Client-event rejections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 7,
      "targets": [{ "expr": "sum by (app_id) (increase(pulsews_rest_throttled_total[5m]))", "legendFormat": "{{app_id}}", "refId": "A" }],
      "title": "REST throttling",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 8,
      "targets": [
        { "expr": "sum by (job) (pulsews_process_resident_memory_bytes)", "legendFormat": "resident", "refId": "A" },
        { "expr": "sum by (job) (pulsews_nodejs_heap_size_used_bytes)", "legendFormat": "heap used", "refId": "B" }
      ],
      "title": "Process memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "id": 9,
      "targets": [{ "expr": "sum(rate(pulsews_process_cpu_seconds_total[1m]))", "legendFormat": "CPU", "refId": "A" }],
      "title": "Process CPU",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "pulsews-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "id": 10,
      "targets": [{ "expr": "max(pulsews_nodejs_eventloop_lag_p99_seconds)", "legendFormat": "p99", "refId": "A" }],
      "title": "Event-loop lag",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 41,
  "tags": ["pulsews"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "title": "PulseWS Overview",
  "uid": "pulsews-overview",
  "version": 1
}
