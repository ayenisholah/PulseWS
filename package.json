{
  "name": "pulsews",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted, Pusher-compatible WebSocket pub/sub server in TypeScript",
  "license": "MIT",
  "author": "Shola Ayeni <ayenisholah@yahoo.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayenisholah/PulseWS.git"
  },
  "homepage": "https://github.com/ayenisholah/PulseWS#readme",
  "bugs": {
    "url": "https://github.com/ayenisholah/PulseWS/issues"
  },
  "keywords": [
    "websocket",
    "pubsub",
    "pusher",
    "realtime",
    "uwebsockets"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run build && npm run lint && npm run test"
  },
  "dependencies": {
    "pino": "10.3.1",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.68.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "pusher": "5.3.4",
    "pusher-js": "8.5.0",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
